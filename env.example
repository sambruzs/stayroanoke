# Stay Roanoke - Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git

# Guesty HQ Account API credentials
VITE_GUESTY_CLIENT_ID=your_client_id_here
VITE_GUESTY_CLIENT_SECRET=your_client_secret_here
VITE_GUESTY_APP_ID=your_application_id_here

# Site info
VITE_SITE_NAME=Stay Roanoke
VITE_SITE_URL=https://stayroanoke.com
VITE_CONTACT_EMAIL=hello@stayroanoke.com
